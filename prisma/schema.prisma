generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [postgis]
}

// ─── ENUMS ────────────────────────────────────────────────────────────────────

enum UserRole {
  ADMIN
  PIT_OWNER
  CONTRACTOR  // legacy — treated as BUYER in app logic
  BUYER       // Direct Buyer
  CARRIER     // 3PL / Trucking Company
  DRIVER      // Independent Truck Driver
}

enum PitType {
  WASTE              // legacy
  BORROW             // legacy
  WASTE_BORROW       // legacy
  PRIVATE_BORROW_PIT
  QUARRY
}

enum HaulOrderStatus {
  PENDING    // awaiting driver/carrier response
  CONFIRMED  // accepted
  DENIED     // declined
  ACTIVE     // in progress
  COMPLETED
  CANCELLED
}

enum PitStatus {
  ACTIVE
  INACTIVE
}

enum TransactionType {
  DUMP
  BORROW
  TOPSOIL
}

enum TransactionStatus {
  PENDING
  SUCCEEDED
  FAILED
  REFUNDED
}

enum OrderStatus {
  ACTIVE
  COMPLETED
  CANCELLED
}

enum OrderType {
  BORROW  // buyer is picking up material FROM the pit
  DUMP    // buyer is dropping waste material INTO the pit
}

enum SettlementStatus {
  PENDING
  PROCESSED
  FAILED
}

enum VerificationMethod {
  GEOFENCE
  OPERATOR
}

enum KycStatus {
  NOT_STARTED
  PENDING
  VERIFIED
  REJECTED
}

enum FlagType {
  UNUSUAL_VOLUME
  RAPID_LOAD_INCREASE
  NEW_ACCOUNT_HIGH_VOLUME
  MANUAL_REVIEW
}

enum FlagResolution {
  CLEARED
  ESCALATED
  REPORTED
}

enum NetTermsInvoiceStatus {
  OPEN
  OVERDUE
  PAID
  WRITTEN_OFF
}

enum IntegrationPlatform {
  PROCORE
  ACC
  QBO
}

enum ClaimStatus {
  PENDING
  APPROVED
  REJECTED
}

// ─── MODELS ───────────────────────────────────────────────────────────────────

model User {
  id             String    @id @default(cuid())
  email          String    @unique
  emailVerified  DateTime?
  name           String?
  image          String?
  hashedPassword String?
  role           UserRole  @default(BUYER)
  phone          String?
  company        String?

  // Stripe Connect (pit owners)
  stripeAccountId String? @unique
  stripeOnboarded Boolean @default(false)

  // Stripe customer (buyers/contractors)
  stripeCustomerId       String? @unique
  defaultPaymentMethodId String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  pits                   Pit[]                   @relation("PitOwner")
  transactions           Transaction[]           @relation("TransactionContractor")
  buyerProjects          Project[]               @relation("BuyerProjects")
  buyerOrders            Order[]                 @relation("BuyerOrders")
  driverLoadEvents       LoadEvent[]             @relation("DriverLoadEvents")
  operatorLoadEvents     LoadEvent[]             @relation("OperatorLoadEvents")
  buyerDriverAssignments DriverAssignment[]      @relation("BuyerDriverAssignments")
  driverAssignments      DriverAssignment[]      @relation("DriverAssignments")
  pitOwnerCompliance     PitOwnerCompliance?
  flagReviews            TransactionFlag[]       @relation("FlagReviewer")
  netTermsAccount        NetTermsAccount?
  buyerNetTermsInvoices  NetTermsInvoice[]       @relation("BuyerNetTermsInvoices")
  integrationConnections IntegrationConnection[]
  pitClaims              PitClaim[]              @relation("ClaimantClaims")
  savedPits              SavedPit[]
  accounts               Account[]
  sessions               Session[]
  driverProfile          DriverProfile?
  carrierProfile         CarrierProfile?
  buyerHaulOrders        HaulOrder[]             @relation("BuyerHaulOrders")

  @@index([role])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Pit {
  id      String  @id @default(cuid())
  name    String
  address String?
  state   String  @default("GA")

  latitude  Float
  longitude Float

  pitType   PitType
  status    PitStatus @default(ACTIVE)
  accepting Boolean   @default(true)

  // Rates stored in cents — material-specific
  dumpRateCents       Int?
  borrowRateCents     Int?
  hasTopsoil          Boolean @default(false)
  topsoilRateCents    Int?
  materialRatesCents  Json    @default("{}")

  // Operator & equipment info
  operatorProvided  Boolean @default(false)
  equipmentProvided Boolean @default(false)
  equipmentNotes    String?

  // Operating hours (HH:MM 24-hour format)
  hoursOpen  String?
  hoursClose String?

  // Geofence radius (admin-only edit)
  geofenceRadiusMeters Int @default(200)

  contactName  String?
  contactPhone String?
  contactEmail String?
  notes        String? @db.Text

  ownerId String?
  owner   User?   @relation("PitOwner", fields: [ownerId], references: [id])

  importedFromKmz Boolean  @default(false)
  kmzUploadId     String?
  materialTypes   String[] @default([])

  // Pit owner locks a daily haul rate → broadcast goes to ALL haulers (drivers + carriers)
  dailyHaulRateCents    Int?
  dailyHaulRateLockedAt DateTime? // null or timestamp of today's lock

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  transactions Transaction[]
  orders       Order[]
  loadEvents   LoadEvent[]
  pitClaims    PitClaim[]
  savedByUsers SavedPit[]
  haulOrders   HaulOrder[]

  @@index([state])
  @@index([accepting])
  @@index([pitType])
  @@index([ownerId])
  @@index([latitude, longitude])
}

model Project {
  id          String @id @default(cuid())
  buyerUserId String
  buyer       User   @relation("BuyerProjects", fields: [buyerUserId], references: [id])

  name        String
  location    String?
  description String?

  // Accounting export fields (all optional, buyer-entered)
  externalJobCode String?
  costCode        String?
  glAccountCode   String?
  qbAccount       String?
  qbClass         String?
  costType        String? @default("Materials")
  taxExempt       Boolean @default(true)

  // Procore integration fields
  procoreCompanyId      String?
  procoreProjectId      String?
  procoreVendorId       String?
  procoreCostCodeId     String?
  procoreLineItemTypeId String?

  // Autodesk ACC integration fields
  accProjectId       String?
  accContainerId     String?
  accBudgetSegmentId String?
  accCompanyId       String?

  orders            Order[]
  driverAssignments DriverAssignment[]
  haulOrders        HaulOrder[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([buyerUserId])
}

model Order {
  id          String  @id @default(cuid())
  projectId   String
  project     Project @relation(fields: [projectId], references: [id])
  pitId       String
  pit         Pit     @relation(fields: [pitId], references: [id])
  buyerUserId String
  buyer       User    @relation("BuyerOrders", fields: [buyerUserId], references: [id])

  status               OrderStatus @default(ACTIVE)
  orderType            OrderType   @default(BORROW)
  estimatedLoads       Int?
  driverPaymentEnabled Boolean     @default(false)

  // Pit operator & equipment snapshot at time of order
  operatorProvided  Boolean @default(false)
  equipmentProvided Boolean @default(false)
  equipmentNotes    String?

  date DateTime @db.Date

  loadEvents             LoadEvent[]
  settlements            Settlement[]
  downPaymentTransaction DownPaymentTransaction?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([projectId])
  @@index([pitId])
  @@index([buyerUserId])
  @@index([date])
  @@index([status])
}

model LoadEvent {
  id      String @id @default(cuid())
  orderId String
  order   Order  @relation(fields: [orderId], references: [id])
  pitId   String
  pit     Pit    @relation(fields: [pitId], references: [id])

  driverUserId   String?
  driver         User?   @relation("DriverLoadEvents", fields: [driverUserId], references: [id])
  operatorUserId String?
  operator       User?   @relation("OperatorLoadEvents", fields: [operatorUserId], references: [id])

  verificationMethod VerificationMethod
  materialType       String // one of ALL_MATERIAL_TYPES
  rateCentsAtTime    Int // snapshot of rate at time of load

  entryTime DateTime?
  exitTime  DateTime?

  manualConfirmed Boolean @default(false)
  disputed        Boolean @default(false)
  verified        Boolean @default(false)

  notes String?

  createdAt DateTime @default(now())

  @@index([orderId])
  @@index([pitId])
  @@index([driverUserId])
  @@index([operatorUserId])
  @@index([verified])
  @@index([createdAt])
}

model Settlement {
  id      String @id @default(cuid())
  orderId String
  order   Order  @relation(fields: [orderId], references: [id])

  date DateTime @db.Date

  verifiedLoadCount Int
  grossAmountCents  Int
  commissionCents   Int
  netToPitCents     Int

  stripeChargeId   String?
  stripeTransferId String?

  status SettlementStatus @default(PENDING)

  buyerPaymentMethod  String  @default("COB")
  pitPayoutSchedule   String  @default("COB")
  pitAdvanceByGotdirt Boolean @default(false)

  netTermsInvoiceId String?
  netTermsInvoice   NetTermsInvoice? @relation(fields: [netTermsInvoiceId], references: [id])

  transactionFlags TransactionFlag[]

  createdAt DateTime @default(now())

  @@unique([orderId, date])
  @@index([orderId])
  @@index([date])
  @@index([status])
}

model DriverAssignment {
  id           String  @id @default(cuid())
  buyerUserId  String
  buyer        User    @relation("BuyerDriverAssignments", fields: [buyerUserId], references: [id])
  driverUserId String
  driver       User    @relation("DriverAssignments", fields: [driverUserId], references: [id])
  projectId    String
  project      Project @relation(fields: [projectId], references: [id])

  active Boolean @default(true)

  createdAt DateTime @default(now())

  @@index([buyerUserId])
  @@index([driverUserId])
  @@index([projectId])
}

model KmzUpload {
  id          String   @id @default(cuid())
  filename    String
  uploadedBy  String
  pitsCreated Int      @default(0)
  createdAt   DateTime @default(now())
}

// Legacy transaction model — kept for historical data
model Transaction {
  id String @id @default(cuid())

  pit          Pit    @relation(fields: [pitId], references: [id])
  pitId        String
  contractor   User   @relation("TransactionContractor", fields: [contractorId], references: [id])
  contractorId String

  pitOwnerAccountId String

  transactionType TransactionType
  loads           Int             @default(1)

  ratePerLoadCents Int
  subtotalCents    Int
  platformFeeCents Int
  ownerPayoutCents Int
  totalChargeCents Int

  platformFeePercent Float

  status TransactionStatus @default(PENDING)

  stripePaymentIntentId String? @unique
  stripeTransferId      String?

  invoice Invoice?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([pitId])
  @@index([contractorId])
  @@index([status])
}

model Invoice {
  id            String      @id @default(cuid())
  invoiceNumber String      @unique
  transaction   Transaction @relation(fields: [transactionId], references: [id])
  transactionId String      @unique
  pdfUrl        String?
  sentToEmail   String?
  createdAt     DateTime    @default(now())
}

model PlatformSettings {
  id                   String   @id @default("singleton")
  feePercent           Float    @default(8.0)   // pit transaction fee %
  haulFeePercent       Float    @default(10.0)  // driver/carrier haul order fee %
  earlyEditFeeCents    Int      @default(1000)  // fee for load edits within 24h
  afterHoursFeeCents   Int      @default(500)   // fee when session ends after 5:30 PM local
  updatedAt            DateTime @updatedAt
  updatedBy            String?
}

model PitOwnerCompliance {
  id             String @id @default(cuid())
  pitOwnerUserId String @unique
  pitOwner       User   @relation(fields: [pitOwnerUserId], references: [id])

  kycStatus           KycStatus @default(NOT_STARTED)
  kycCompletedAt      DateTime?
  stripeOnboardingUrl String?
  payoutsEnabled      Boolean   @default(false)
  chargesEnabled      Boolean   @default(false)
  requirementsDue     String[]  @default([])
  lastCheckedAt       DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([kycStatus])
}

model TransactionFlag {
  id           String          @id @default(cuid())
  settlementId String
  settlement   Settlement      @relation(fields: [settlementId], references: [id])
  flagType     FlagType
  description  String
  reviewedBy   String?
  reviewer     User?           @relation("FlagReviewer", fields: [reviewedBy], references: [id])
  reviewedAt   DateTime?
  resolution   FlagResolution?

  createdAt DateTime @default(now())

  @@index([settlementId])
  @@index([resolution])
}

// ─── PHASE 2: NET TERMS ───────────────────────────────────────────────────────

model NetTermsAccount {
  id          String @id @default(cuid())
  buyerUserId String @unique
  buyer       User   @relation(fields: [buyerUserId], references: [id])

  termsDays         Int   @default(30) // e.g. 30, 45, 60
  creditLimitCents  Int? // optional credit cap (null = no limit)
  downPaymentPct    Float @default(0) // % charged at order placement
  billingPeriodDays Int   @default(30) // how often invoices are generated

  notes      String? @db.Text
  assignedBy String // admin userId who set these terms

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  netTermsInvoices NetTermsInvoice[]

  @@index([buyerUserId])
}

model NetTermsInvoice {
  id                String          @id @default(cuid())
  netTermsAccountId String
  netTermsAccount   NetTermsAccount @relation(fields: [netTermsAccountId], references: [id])
  buyerUserId       String
  buyer             User            @relation("BuyerNetTermsInvoices", fields: [buyerUserId], references: [id])

  invoiceNumber String   @unique
  periodStart   DateTime @db.Date
  periodEnd     DateTime @db.Date
  dueDate       DateTime @db.Date

  subtotalCents   Int
  commissionCents Int
  totalDueCents   Int

  status NetTermsInvoiceStatus @default(OPEN)

  pdfUrl                String?
  stripeInvoiceId       String? @unique
  stripePaymentIntentId String? @unique

  // Overdue reminder tracking
  reminderSentAt   DateTime?
  plus3SentAt      DateTime?
  plus7SentAt      DateTime?
  plus15SentAt     DateTime?
  escalatedToAdmin Boolean   @default(false)

  settlements Settlement[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Idempotency: one invoice per buyer per billing period
  @@unique([buyerUserId, periodStart, periodEnd])
  @@index([buyerUserId])
  @@index([status])
  @@index([dueDate])
}

model DownPaymentTransaction {
  id      String @id @default(cuid())
  orderId String @unique
  order   Order  @relation(fields: [orderId], references: [id])

  amountCents           Int
  stripePaymentIntentId String?           @unique
  status                TransactionStatus @default(PENDING)

  createdAt DateTime @default(now())
}

// ─── PHASE 2: INTEGRATIONS ────────────────────────────────────────────────────

model IntegrationConnection {
  id          String @id @default(cuid())
  buyerUserId String
  buyer       User   @relation(fields: [buyerUserId], references: [id])

  platform IntegrationPlatform

  // AES-256 encrypted OAuth tokens (never stored in plaintext)
  accessTokenEnc  String    @db.Text
  refreshTokenEnc String?   @db.Text
  expiresAt       DateTime?

  // Platform-specific identifiers
  platformUserId    String?
  platformCompanyId String?
  platformOrgId     String?
  scope             String?

  lastSyncAt    DateTime?
  lastSyncError String?   @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([buyerUserId, platform])
  @@index([buyerUserId])
  @@index([platform])
}

// ─── PHASE 3: PIT CLAIMS + SAVED PITS ────────────────────────────────────────

model PitClaim {
  id         String @id @default(cuid())
  pitId      String
  pit        Pit    @relation(fields: [pitId], references: [id])
  claimantId String
  claimant   User   @relation("ClaimantClaims", fields: [claimantId], references: [id])

  status     ClaimStatus @default(PENDING)
  message    String?     @db.Text // owner's note explaining claim
  adminNotes String?     @db.Text
  reviewedBy String?
  reviewedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([pitId, claimantId])
  @@index([pitId])
  @@index([claimantId])
  @@index([status])
}

model SavedPit {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  pitId     String
  pit       Pit      @relation(fields: [pitId], references: [id])
  createdAt DateTime @default(now())

  @@unique([userId, pitId])
  @@index([userId])
  @@index([pitId])
}

// ─── DRIVER / CARRIER / HAUL ORDER MODELS ────────────────────────────────────

model DriverProfile {
  id     String @id @default(cuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Public profile
  bio           String? @db.Text
  profilePublic Boolean @default(false)

  // Haul details — visible to Direct Buyers only, never to CarrierProfiles
  haulRateCents Int?    // per load
  truckType     String? // e.g. "Super 10 Dump", "Tri-Axle Dump"

  // Compliance documents (Supabase Storage URLs)
  gdotLicenseUrl    String?
  insuranceUrl      String?
  additionalDocUrls String[] @default([])
  docsVerified      Boolean  @default(false)

  // Live location (driver-controlled toggle)
  liveLocationEnabled Boolean  @default(false)
  currentLat          Float?
  currentLng          Float?
  lastLocationAt      DateTime?

  haulOrders HaulOrder[] @relation("DriverHaulOrders")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model CarrierProfile {
  id     String @id @default(cuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Public profile
  companyName   String?
  bio           String? @db.Text
  website       String?
  profilePublic Boolean @default(false)

  // Haul rate — visible to Direct Buyers only, NEVER to DriverProfiles
  haulRateCents Int? // per load baseline

  terminals  CarrierTerminal[]
  haulOrders HaulOrder[]       @relation("CarrierHaulOrders")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model CarrierTerminal {
  id        String         @id @default(cuid())
  carrierId String
  carrier   CarrierProfile @relation(fields: [carrierId], references: [id], onDelete: Cascade)

  name    String
  address String?
  lat     Float
  lng     Float

  createdAt DateTime @default(now())

  @@index([carrierId])
}

model HaulOrder {
  id          String @id @default(cuid())
  buyerUserId String
  buyer       User   @relation("BuyerHaulOrders", fields: [buyerUserId], references: [id])

  // Fulfilled by a driver OR a carrier (mutually exclusive)
  driverId  String?
  driver    DriverProfile?  @relation("DriverHaulOrders", fields: [driverId], references: [id])
  carrierId String?
  carrier   CarrierProfile? @relation("CarrierHaulOrders", fields: [carrierId], references: [id])

  pitId     String?
  pit       Pit?     @relation(fields: [pitId], references: [id])
  projectId String?
  project   Project? @relation(fields: [projectId], references: [id])

  scheduledDate       DateTime
  loads               Int  // estimated loads at order placement
  actualLoads         Int? // actual loads on completion (null until completed)
  haulRateCents       Int  // rate locked at order placement
  totalEstimatedCents Int
  depositHoldCents    Int  // partial card hold amount

  // Platform fee snapshot — recalculated on completion using actualLoads
  platformFeePercent Float @default(0)
  platformFeeCents   Int   @default(0)  // Got Dirt? revenue on this order
  haulerPayoutCents  Int   @default(0)  // what the driver/carrier receives

  stripePaymentIntentId String? @unique

  broadcast        Boolean @default(false) // open-broadcast order
  pitRateBroadcast Boolean @default(false) // rate locked by pit owner → goes to all haulers

  status    HaulOrderStatus @default(PENDING)
  expiresAt DateTime?       // first-come-first-served cutoff

  notes String? @db.Text

  pitOwnerApproved    Boolean?  // null=awaiting review, true=accepted, false=denied
  pitOwnerRespondedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Buyer self-haul (Buyer/Operator mode — cost tracking only, no hauler)
  buyerOperating         Boolean @default(false)
  operatorTruckType      String?
  operatorTruckRateCents Int?

  // Pit owner starts a load-log session to unlock the driver's tap button
  pitSessionActive      Boolean   @default(false)
  pitSessionStartedAt   DateTime?
  pitSessionStartedBy   String?   // pit owner userId

  driverManualArrival   Boolean   @default(false)
  driverManualArrivalAt DateTime?

  // COB settlement fields — set when pit owner ends the load session
  pitSessionEndedAt   DateTime?
  cobDueAt            DateTime? // 5:30 PM local time on session-end day (UTC stored)
  afterHoursFeeCents  Int       @default(0) // extra fee if session ended after COB

  amendments       HaulOrderAmendment[]
  driverLoadLogs   DriverLoadLog[]
  pitOwnerLoadLogs PitOwnerLoadLog[]

  @@index([buyerUserId])
  @@index([driverId])
  @@index([carrierId])
  @@index([status])
  @@index([scheduledDate])
}

model HaulOrderAmendment {
  id          String    @id @default(cuid())
  haulOrderId String
  haulOrder   HaulOrder @relation(fields: [haulOrderId], references: [id])

  requestedByUserId String  // buyer's userId

  originalLoads  Int
  requestedLoads Int

  reason String? @db.Text

  // PENDING | APPROVED | DENIED | WITHDRAWN
  status String @default("PENDING")

  // Hauler response (driver or carrier — whoever is on the order)
  haulerApproved    Boolean?
  haulerRespondedAt DateTime?
  haulerNotes       String?   @db.Text

  // Pit owner response (null if pit has no owner or order has no pit)
  pitOwnerApproved    Boolean?
  pitOwnerRespondedAt DateTime?
  pitOwnerNotes       String?   @db.Text

  processingFeeCents Int @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([haulOrderId])
  @@index([status])
  @@index([requestedByUserId])
}

model DriverLoadLog {
  id           String    @id @default(cuid())
  haulOrderId  String
  haulOrder    HaulOrder @relation(fields: [haulOrderId], references: [id])
  driverUserId String

  lat     Float?
  lng     Float?
  speed   Float? // GPS speed in m/s at time of tap

  loggedAt DateTime @default(now())

  @@index([haulOrderId])
  @@index([driverUserId])
}

model PitOwnerLoadLog {
  id             String    @id @default(cuid())
  haulOrderId    String
  haulOrder      HaulOrder @relation(fields: [haulOrderId], references: [id])
  pitOwnerUserId String
  loggedAt       DateTime  @default(now())

  @@index([haulOrderId])
  @@index([pitOwnerUserId])
}
